{
  "name": "happy-paws-store",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "preview": "pnpm --filter web preview",
    "db:generate": "pnpm --filter @happy-paws/db db:generate",
    "db:migrate": "pnpm --filter @happy-paws/db db:migrate",
    "db:push": "pnpm --filter @happy-paws/db db:push",
    "db:studio": "pnpm --filter @happy-paws/db db:studio",
    "db:seed": "pnpm --filter @happy-paws/db db:seed"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.3.1"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "jiti",
        "lightningcss",
        "tsx"
      ]
    }
  }
}
